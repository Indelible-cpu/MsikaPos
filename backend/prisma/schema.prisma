generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Role {
  id          Int      @id @default(autoincrement())
  name        RoleName @unique
  description String?
  users       User[]
}

model User {
  id                 Int        @id @default(autoincrement())
  username           String     @unique
  password           String
  roleId             Int
  branchId           Int?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  deleted            Boolean    @default(false)
  email              String?
  fullname           String?
  homeAddress        String?
  isVerified         Boolean    @default(false)
  mustChangePassword Boolean    @default(true)
  nextOfKinPhone     String?
  phone              String?
  profilePic         String?
  relationship       String?
  verificationCode   String?
  nationalId         String?
  auth_id            String?    @unique(map: "unique_auth_id") @db.Uuid
  magicToken         String?    @unique
  magicTokenExpires  DateTime?
  nextOfKinName      String?
  status             UserStatus @default(ACTIVE)
  customer           Customer?
  expenses           Expense[]
  sales              Sale[]
  branch             Branch?    @relation(fields: [branchId], references: [id])
  role               Role       @relation(fields: [roleId], references: [id])

  @@index([roleId])
  @@index([branchId])
  @@index([deleted])
  @@index([username])
}

model Branch {
  id           Int           @id @default(autoincrement())
  name         String
  location     String?
  phone        String?
  status       BranchStatus  @default(ACTIVE)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  email        String?
  facebook     String?
  logo         String?
  slogan       String?
  customers    Customer[]
  expenses     Expense[]
  inquiries    Inquiry[]
  products     Product[]
  sales        Sale[]
  securityLogs SecurityLog[]
  syncLogs     SyncLog[]
  users        User[]
}

model Category {
  id       Int       @id @default(autoincrement())
  slug     String    @unique
  title    String
  products Product[]
}

model Product {
  id                Int        @id @default(autoincrement())
  categoryId        Int
  sku               String?    @unique
  name              String
  description       String?
  costPrice         Decimal    @db.Decimal(10, 2)
  sellPrice         Decimal    @db.Decimal(10, 2)
  taxRate           Decimal    @default(0.00) @db.Decimal(5, 2)
  quantity          Int        @default(0)
  isService         Boolean    @default(false)
  branchId          Int?
  deleted           Boolean    @default(false)
  synced            Boolean    @default(true)
  deviceId          String?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  imageUrl          String?
  discountEndDate   DateTime?
  discountStartDate DateTime?
  discountType      String?
  discountValue     Decimal?   @default(0.00) @db.Decimal(10, 2)
  branch            Branch?    @relation(fields: [branchId], references: [id])
  category          Category   @relation(fields: [categoryId], references: [id])
  saleItems         SaleItem[]

  @@index([categoryId])
  @@index([branchId])
  @@index([deleted])
  @@index([sku])
  @@index([name])
}

model Customer {
  id            Int       @id @default(autoincrement())
  offlineId     String?   @unique
  fullname      String
  phone         String
  email         String?
  address       String?
  loyaltyPoints Int       @default(0)
  idNumber      String?
  village       String?
  locationId    String?
  livePhoto     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  userId        Int?      @unique
  branchId      Int?
  branch        Branch?   @relation(fields: [branchId], references: [id])
  user          User?     @relation(fields: [userId], references: [id])
  inquiries     Inquiry[]
  sales         Sale[]

  @@index([branchId])
}

model Inquiry {
  id         Int      @id @default(autoincrement())
  customerId Int
  items      String
  status     String   @default("PENDING")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  branchId   Int?
  branch     Branch?  @relation(fields: [branchId], references: [id])
  customer   Customer @relation(fields: [customerId], references: [id])

  @@index([branchId])
}

model Sale {
  id          String      @id @default(cuid())
  invoiceNo   String      @unique
  receiptNo   String?
  userId      Int
  branchId    Int?
  customerId  Int?
  subtotal    Decimal     @db.Decimal(10, 2)
  discount    Decimal     @default(0.00) @db.Decimal(10, 2)
  total       Decimal     @db.Decimal(10, 2)
  paid        Decimal     @db.Decimal(10, 2)
  changeDue   Decimal     @default(0.00) @db.Decimal(10, 2)
  profit      Decimal     @db.Decimal(10, 2)
  paymentMode PaymentMode @default(CASH)
  status      SaleStatus  @default(COMPLETED)
  taxRate     Decimal     @default(0.00) @db.Decimal(5, 2)
  taxAmount   Decimal     @default(0.00) @db.Decimal(10, 2)
  isCredit    Boolean     @default(false)
  dueDate     DateTime?
  itemsCount  Int         @default(0)
  synced      Boolean     @default(false)
  deviceId    String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  branch      Branch?     @relation(fields: [branchId], references: [id])
  customer    Customer?   @relation(fields: [customerId], references: [id])
  user        User        @relation(fields: [userId], references: [id])
  items       SaleItem[]

  @@index([userId])
  @@index([branchId])
  @@index([customerId])
  @@index([paymentMode])
  @@index([status])
  @@index([createdAt])
  @@index([invoiceNo])
}

model SaleItem {
  id          Int      @id @default(autoincrement())
  saleId      String
  productId   Int
  productName String
  unitPrice   Decimal  @db.Decimal(10, 2)
  quantity    Int      @default(1)
  discount    Decimal  @default(0.00) @db.Decimal(10, 2)
  lineTotal   Decimal  @db.Decimal(10, 2)
  profit      Decimal  @db.Decimal(10, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  product     Product  @relation(fields: [productId], references: [id])
  sale        Sale     @relation(fields: [saleId], references: [id])

  @@index([saleId])
  @@index([productId])
}

model Expense {
  id            Int      @id @default(autoincrement())
  category      String
  amount        Decimal  @db.Decimal(12, 2)
  description   String?
  paymentMethod String   @default("Cash")
  expenseDate   DateTime
  userId        Int
  branchId      Int?
  createdAt     DateTime @default(now())
  branch        Branch?  @relation(fields: [branchId], references: [id])
  user          User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([branchId])
  @@index([expenseDate])
}

model SyncLog {
  id        Int      @id @default(autoincrement())
  deviceId  String
  userId    Int
  action    String
  status    String
  details   String?
  createdAt DateTime @default(now())
  branchId  Int?
  branch    Branch?  @relation(fields: [branchId], references: [id])

  @@index([branchId])
}

model CompanySettings {
  id              Int      @id @default(autoincrement())
  companyName     String?
  slogan          String?
  address         String?
  phone           String?
  email           String?
  logo            String?
  facebookPage    String?
  primaryColor    String?  @default("#6366f1")
  currency        String?  @default("MK")
  global_discount Decimal? @default(0.00) @db.Decimal(10, 2)
  tax_config      String?
}

model SecurityLog {
  id        Int      @id @default(autoincrement())
  ipAddress String
  event     String
  details   String?
  createdAt DateTime @default(now())
  branchId  Int?
  branch    Branch?  @relation(fields: [branchId], references: [id])

  @@index([branchId])
}

model BlockedIP {
  id        Int       @id @default(autoincrement())
  ipAddress String    @unique
  reason    String
  blockedAt DateTime  @default(now())
  expiresAt DateTime?
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DEACTIVATED
}

enum RoleName {
  SUPER_ADMIN
  ADMIN
  CASHIER
  CUSTOMER
}

enum BranchStatus {
  ACTIVE
  INACTIVE
}

enum PaymentMode {
  CASH
  CARD
  MOBILE_MONEY
  CREDIT
}

enum SaleStatus {
  COMPLETED
  PENDING
  DELETED
}
