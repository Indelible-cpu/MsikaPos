generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Role {
  id          Int      @id @default(autoincrement())
  name        RoleName @unique
  description String?
  users       User[]
}

model User {
  id                 Int        @id @default(autoincrement())
  username           String     @unique
  password           String
  roleId             Int
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  deleted            Boolean    @default(false)
  email              String?
  fullname           String?
  homeAddress        String?
  isVerified         Boolean    @default(false)
  mustChangePassword Boolean    @default(true)
  nextOfKinPhone     String?
  phone              String?
  profilePic         String?
  relationship       String?
  verificationCode   String?
  nationalId         String?
  auth_id            String?    @unique(map: "unique_auth_id") @db.Uuid
  magicToken         String?    @unique
  magicTokenExpires  DateTime?
  nextOfKinName      String?
  status             UserStatus @default(ACTIVE)
  hasBiometrics      Boolean    @default(false)
  customer           Customer?
  expenses           Expense[]
  sales              Sale[]
  role               Role       @relation(fields: [roleId], references: [id])
  business           Business?  @relation(fields: [businessId], references: [id])
  businessId         Int?
  salaryConfig       EmployeeSalaryConfig?
  advances           SalaryAdvance[]      @relation("advances")
  approvedAdvances   SalaryAdvance[]      @relation("approvedAdvances")
  payslips           Payslip[]

  @@index([roleId])
  @@index([deleted])
  @@index([username])
}

model Category {
  id         Int       @id @default(autoincrement())
  slug       String    @unique
  title      String
  products   Product[]
  business   Business? @relation(fields: [businessId], references: [id])
  businessId Int?
}

model Product {
  id                Int              @id @default(autoincrement())
  categoryId        Int
  sku               String?          @unique
  name              String
  description       String?
  costPrice         Decimal          @db.Decimal(10, 2)
  sellPrice         Decimal          @db.Decimal(10, 2)
  taxRate           Decimal          @default(0.00) @db.Decimal(5, 2)
  quantity          Int              @default(0)
  isService         Boolean          @default(false)
  deleted           Boolean          @default(false)
  synced            Boolean          @default(true)
  deviceId          String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  imageUrl          String?
  discountEndDate   DateTime?
  discountStartDate DateTime?
  discountType      String?
  discountValue     Decimal?         @default(0.00) @db.Decimal(10, 2)
  category          Category         @relation(fields: [categoryId], references: [id])
  saleItems         SaleItem[]
  ratings           ProductRating[]
  business          Business?        @relation(fields: [businessId], references: [id])
  businessId        Int?
  productVariants   ProductVariant[]

  @@index([categoryId])
  @@index([deleted])
  @@index([sku])
  @@index([name])
  @@index([updatedAt])
}

model Customer {
  id            Int             @id @default(autoincrement())
  offlineId     String?         @unique
  fullname      String
  phone         String
  email         String?
  address       String?
  loyaltyPoints Int             @default(0)
  idNumber      String?
  village       String?
  locationId    String?
  livePhoto     String?
  balance       Decimal         @default(0.00) @db.Decimal(12, 2)
  totalDebt     Decimal         @default(0.00) @db.Decimal(12, 2)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  userId        Int?            @unique
  user          User?           @relation(fields: [userId], references: [id])
  inquiries     Inquiry[]
  sales         Sale[]
  ratings       ProductRating[]
  debtPayments  DebtPayment[]
  business      Business?       @relation(fields: [businessId], references: [id])
  businessId    Int?

  @@index([phone])
  @@index([fullname])
  @@index([updatedAt])
}

model Inquiry {
  id         Int       @id @default(autoincrement())
  customerId Int
  items      String
  status     String    @default("PENDING")
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  customer   Customer  @relation(fields: [customerId], references: [id])
  business   Business? @relation(fields: [businessId], references: [id])
  businessId Int?
}

model Sale {
  id           String      @id @default(cuid())
  invoiceNo    String      @unique
  receiptNo    String?
  userId       Int
  customerId   Int?
  subtotal     Decimal     @db.Decimal(10, 2)
  discount     Decimal     @default(0.00) @db.Decimal(10, 2)
  total        Decimal     @db.Decimal(10, 2)
  paid         Decimal     @db.Decimal(10, 2)
  changeDue    Decimal     @default(0.00) @db.Decimal(10, 2)
  profit       Decimal     @db.Decimal(10, 2)
  paymentMode  PaymentMode @default(CASH)
  status       SaleStatus  @default(COMPLETED)
  taxRate      Decimal     @default(0.00) @db.Decimal(5, 2)
  taxAmount    Decimal     @default(0.00) @db.Decimal(10, 2)
  isCredit     Boolean     @default(false)
  dueDate      DateTime?
  refundReason String?
  itemsCount   Int         @default(0)
  synced       Boolean     @default(false)
  deviceId     String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  customer     Customer?   @relation(fields: [customerId], references: [id])
  user         User        @relation(fields: [userId], references: [id])
  items        SaleItem[]
  business     Business?   @relation(fields: [businessId], references: [id])
  businessId   Int?

  @@index([userId])
  @@index([customerId])
  @@index([paymentMode])
  @@index([status])
  @@index([createdAt])
  @@index([invoiceNo])
}

model SaleItem {
  id          Int      @id @default(autoincrement())
  saleId      String
  productId   Int
  productName String
  unitPrice   Decimal  @db.Decimal(10, 2)
  quantity    Int      @default(1)
  discount    Decimal  @default(0.00) @db.Decimal(10, 2)
  lineTotal   Decimal  @db.Decimal(10, 2)
  profit      Decimal  @db.Decimal(10, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  product     Product  @relation(fields: [productId], references: [id])
  sale        Sale     @relation(fields: [saleId], references: [id])

  @@index([saleId])
  @@index([productId])
}

model DebtPayment {
  id            String    @id @default(cuid())
  customerId    Int
  amount        Decimal   @db.Decimal(12, 2)
  paymentMethod String
  reference     String?
  createdAt     DateTime  @default(now())
  customer      Customer  @relation(fields: [customerId], references: [id])
  business      Business? @relation(fields: [businessId], references: [id])
  businessId    Int?

  @@index([customerId])
}

model Expense {
  id            String    @id @default(cuid())
  category      String
  amount        Decimal   @db.Decimal(12, 2)
  description   String?
  paymentMethod String    @default("Cash")
  expenseDate   DateTime
  userId        Int
  createdAt     DateTime  @default(now())
  user          User      @relation(fields: [userId], references: [id])
  business      Business? @relation(fields: [businessId], references: [id])
  businessId    Int?

  @@index([userId])
  @@index([expenseDate])
}

model SyncLog {
  id         Int       @id @default(autoincrement())
  deviceId   String
  userId     Int
  action     String
  status     String
  details    String?
  createdAt  DateTime  @default(now())
  business   Business? @relation(fields: [businessId], references: [id])
  businessId Int?
}

model CompanySettings {
  id              Int       @id @default(autoincrement())
  companyName     String?
  slogan          String?
  address         String?
  phone           String?
  email           String?
  logo            String?
  facebookPage    String?
  primaryColor    String?   @default("#6366f1")
  currency        String?   @default("MK")
  global_discount Decimal?  @default(0.00) @db.Decimal(10, 2)
  tax_config      String?
  savingsPercentage Decimal? @default(0.00) @db.Decimal(5, 2)
  business        Business? @relation(fields: [businessId], references: [id])
  businessId      Int?
}

model SecurityLog {
  id        Int      @id @default(autoincrement())
  ipAddress String
  ipSource  String   @default("unknown")
  event     String
  details   String?
  createdAt DateTime @default(now())
}

model BlockedIP {
  id        Int       @id @default(autoincrement())
  ipAddress String    @unique
  reason    String
  blockedAt DateTime  @default(now())
  expiresAt DateTime?
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DEACTIVATED
}

enum RoleName {
  SUPER_ADMIN
  ADMIN
  CASHIER
  CUSTOMER
  EMPLOYEE
}

enum PaymentMode {
  CASH
  CARD
  MOBILE_MONEY
  CREDIT
}

enum SaleStatus {
  COMPLETED
  PENDING
  DELETED
  REFUNDED
}

model ProductRating {
  id         Int       @id @default(autoincrement())
  productId  Int
  customerId Int?
  rating     Int // 1-5 stars
  comment    String?
  createdAt  DateTime  @default(now())
  product    Product   @relation(fields: [productId], references: [id])
  customer   Customer? @relation(fields: [customerId], references: [id])

  @@index([productId])
}

model FeatureConfig {
  id          Int      @id @default(autoincrement())
  featureKey  String
  roleName    RoleName
  accessLevel String // "HIDDEN", "READ_ONLY", "FULL"

  @@unique([featureKey, roleName])
}

model Business {
  id        Int      @id @default(autoincrement())
  name      String
  type      String   @default("GENERAL")
  settings  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users           User[]
  categories      Category[]
  products        Product[]
  customers       Customer[]
  sales           Sale[]
  expenses        Expense[]
  syncLogs        SyncLog[]
  companySettings CompanySettings[]
  inquiries       Inquiry[]
  debtPayments    DebtPayment[]
}

model ProductVariant {
  id        Int      @id @default(autoincrement())
  productId Int
  name      String
  sku       String?
  costPrice Decimal? @db.Decimal(10, 2)
  sellPrice Decimal? @db.Decimal(10, 2)
  quantity  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

// ─── PAYROLL MODELS ──────────────────────────────────────────────────────────

model EmployeeSalaryConfig {
  id            Int      @id @default(autoincrement())
  userId        Int      @unique
  basicSalary   Decimal  @db.Decimal(12, 2)
  allowances    Decimal  @default(0) @db.Decimal(12, 2)
  deductions    Decimal  @default(0) @db.Decimal(12, 2)
  currency      String   @default("MWK")
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id])
}

model SalaryAdvance {
  id          Int       @id @default(autoincrement())
  userId      Int
  amount      Decimal   @db.Decimal(12, 2)
  reason      String?
  status      String    @default("PENDING")
  requestedAt DateTime  @default(now())
  approvedAt  DateTime?
  repaidAt    DateTime?
  approvedBy  Int?
  user        User      @relation("advances", fields: [userId], references: [id])
  approver    User?     @relation("approvedAdvances", fields: [approvedBy], references: [id])

  @@index([userId])
  @@index([status])
}

model Payslip {
  id            Int      @id @default(autoincrement())
  userId        Int
  month         Int
  year          Int
  basicSalary   Decimal  @db.Decimal(12, 2)
  allowances    Decimal  @db.Decimal(12, 2)
  deductions    Decimal  @db.Decimal(12, 2)
  advanceDeduct Decimal  @default(0) @db.Decimal(12, 2)
  netPay        Decimal  @db.Decimal(12, 2)
  status        String   @default("DRAFT")
  notes         String?
  generatedAt   DateTime @default(now())
  signature     String?  @db.Text
  signedBy      String?
  signedByRole  String?
  signedAt      DateTime?
  user          User     @relation(fields: [userId], references: [id])

  @@unique([userId, month, year])
  @@index([year, month])
}
